{
  "name": "prafood-agente-impressao",
  "version": "1.0.0",
  "description": "Agente de Impressão Local PraFood",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32",
    "make:mac": "electron-forge make --platform=darwin"
  },
  "dependencies": {
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "3.0.0-alpha.1",
    "local-devices": "^4.0.0",
    "pdf-to-printer": "^5.8.0",
    "pdfkit": "^0.18.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/plugin-fuses": "^7.2.0",
    "electron": "^28.0.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "PraFood Impressor",
        "asar": true
      },
      "rebuildConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "prafood_agente_impressao"
          }
        },
        {
          "name": "@electron-forge/maker-dmg",
          "config": {
            "name": "PraFood Impressor",
            "overwrite": true
          }
        }
      ]
    }
  }
}
